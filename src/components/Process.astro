---
export interface Step {
  number: string;
  title: string;
  desc: string;
}

export interface Props {
  label: string;
  title: string;
  desc: string;
  steps: Step[];
}

const { label, title, desc, steps } = Astro.props;
---

<section class="process" id="process">
  <div class="container">
    <span class="section-label fade-in">{label}</span>
    <h2 class="section-title fade-in" data-delay="1">{title}</h2>
    <p class="section-desc fade-in" data-delay="2">{desc}</p>
    <div class="process-steps">
      {steps.map((step, i) => (
        <div class="step fade-in" data-delay={i + 1}>
          <div class="step-circle">{step.number}</div>
          <h3>{step.title}</h3>
          <p>{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
